# Destino: "postgres" ou "sheets"
DATA_SOURCE=postgres

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/coupler_monitor

# Google Sheets (se DATA_SOURCE=sheets)
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
GOOGLE_SHEETS_WORKSHEET_NAME=google_ads_data

# Alertas (futuro: slack webhook, email, etc.)
ALERT_MODE=log

# Limiar de spend para considerar "zerou"
SPEND_THRESHOLD=1.0
